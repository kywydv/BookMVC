@model BookMVC.Domain.Entities.Genre

@{
    ViewData["Title"] = "Видалити жанр";
}

<h1>Видалити жанр</h1>

<h3>Ви впевнені, що хочете видалити цей жанр?</h3>
<dl class="row">
    <dt class="col-sm-2">Назва</dt>
    <dd class="col-sm-10">@Model.Name</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Видалити</button> |
    <a asp-action="Index">Скасувати</a>
</form>